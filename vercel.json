{
  "builds": [
    {
      "src": "api/**/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/market-monitor",
      "dest": "api/market_monitor.py"
    },
    {
      "src": "/api/price/(.*)",
      "dest": "api/price.py?symbol=$1"
    },
    {
      "src": "/",
      "dest": "index.html"
    }
  ]
}